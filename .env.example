# Aura — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# OpenAI API Key — used for GPT-4o-mini itinerary generation
EXPO_PUBLIC_OPENAI_API_KEY=sk-...

# Google Places API (New) — for high-quality location photography
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=AIza...

# Unsplash Access Key — fallback imagery source
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=...
